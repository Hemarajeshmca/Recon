    function threadmessage(ticketgid, ticketno) {
        var usercode = sessionStorage.getItem("usrname");
        var username = sessionStorage.getItem("username");
        var payload = {
            in_user_code: usercode,
            in_ticket_gid: ticketgid,
            in_ticket_no: ticketno,
            in_lang_code: '',
            in_ip_addr: '',
            in_action: ''
        };
        $.ajax({
            type: "POST",
            url: '../Ticket/threadFetch',
            data: JSON.stringify(payload),// ✅ send whole object directly
            contentType: "application/json; charset=utf-8",
            success: function (response) {
                var result = JSON.parse(response);
                console.log("threads : ", result);
                var threadDiv = $("#thread");
                var tabthreadDiv = $("#tabthread");
                threadDiv.empty(); // Clear previous content
                tabthreadDiv.empty(); // Clear previous content

                result.forEach(function (item) {
                    // Format date (optional: show only date & time nicely)
                        var ticketDate = new Date(item.Ticket_date);

                        var formattedDate = ticketDate.toLocaleString('en-GB', {
                            day: '2-digit',
                            month: '2-digit',
                            year: 'numeric',
                            hour: '2-digit',
                            minute: '2-digit',
                            second: '2-digit',
                            hour12: true
                        });

                    // Build message block
                    var messageHTML = `
                        <div style="margin-bottom:10px; border-bottom:1px solid #ccc; padding:8px; border-radius:6px; background-color:#f2f2f2;">
                            <div style="display:flex; justify-content:space-between; font-weight:normal;">
                                 <span>${item.user_name} - Date : ${formattedDate} - Status : ${item.Queue_status}</span>
                            </div>
                            <div style="margin-top:3px;">${item.queue_remarks}</div>
                        </div>
                    `;
                    threadDiv.append(messageHTML);

                    var tabmessageHTML = `
                        <div style="margin-bottom:10px; border-bottom:1px solid #ccc; padding:8px; border-radius:6px; background-color:#f2f2f2;">
                            <div style="display:flex; justify-content:space-between; font-weight:normal;">
                                <span>${item.user_name} - Date : ${formattedDate} - Status : ${item.Queue_status}</span>
                            </div>
                            <div style="margin-top:3px;">${item.queue_remarks}</div>
                        </div>
                    `;
                    tabthreadDiv.append(tabmessageHTML);
                });
            },
            error: function (er) {
                alert(er)
                console.log(er)
            }
        });
    }

