<script type="text/javascript">
	var fields = {};
	var preSelected = "";
	var arr = [];
	$(document).ready(function () {
		$("#navhead").text("Recon Field Update");
		var data = getlocalStorage("ls_pageList");
		var jsondata = {};
		jsondata.in_recon_code = sessionStorage.getItem("reconcode");
		jsondata.in_user_code = sessionStorage.getItem("usrname");
		$.ajax({
			type: "POST",
			url: '../KoSequence/reconfieldinfo',
			dataType: 'json',
			async: false,
			data: JSON.stringify(jsondata),
			contentType: 'application/json; charset=utf-8',
			success: function (response) {
				var res = JSON.parse(response);
				var jsondata1 = {};
			jsondata1.in_tran_gid = data.entries[(res[0].position_tran_gid) -1];
			jsondata1.in_recon_code = sessionStorage.getItem("reconcode");
			jsondata1.in_tranbrkp_gid = res[0].position_tranbrkp_gid;
			$("#trabbrkid").val(0);
			jsondata1.in_user_code = sessionStorage.getItem("usrname");
			$.ajax({
				type: "POST",
				url: '../KoSequence/getreconvalue',
				dataType: 'json',
				async: false,
				data: JSON.stringify(jsondata1),
				contentType: 'application/json; charset=utf-8',
				success: function (response) {
				  var result = JSON.parse(response);
				  fields =result.Table
					$("#reportid").val((getValueByDesc("Report ID")));
					$("#employeeid").val((getValueByDesc("Employee ID")));;
					$("#name").val((getValueByDesc("Name")));
					$("#grade").val((getValueByDesc("Grade")));
					$("#expencetype").val((getValueByDesc("Expense Type")));
					$("#category").val((getValueByDesc("Category")));
					$("#transts").val((getValueByDesc("Transaction Status")));
					$("#approveamt").val((getValueByDesc("Gross Amount")));
					$("#subcategory").val((getValueByDesc("Subcategories")));
					$("#description").val((getValueByDesc("Description")));
					$("#emailid").val((getValueByDesc("Email ID")));
					$("#actor3").val((getValueByDesc("Actor3")));
					$("#tknat3").val((getValueByDesc("Taken At3")));
					$("#dtofexpence").val((getValueByDesc("Date of expense")));
					$("#ahloc").val(getValueByDesc("AH Location"));
					$("#ahdept").val((getValueByDesc("AH Department")));
					$("#designation").val(getValueByDesc("Designation"));
				}
			});
			}
		});
		

			var in_master_code = getparentByDesc("Doc Type");
			var in_user_code = sessionStorage.getItem("usrname");
			$.ajax({
				type: "POST",
				url: '../Common/Qcdmaster',
				dataType: 'json',
					async: false,
