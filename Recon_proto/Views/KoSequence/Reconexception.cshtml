	function pagination(data) {
		if (data == "next") {
			var Actpageno = Math.ceil(parseFloat(result) / parseFloat(pagesize));
			if (pageno > Actpageno) {
				$.alert({
					title: 'Recon',
					content: "Page number is greater than total number of page",
					type: 'red',
				});
				return;
			} else if (pageno == Actpageno) {
				currentpage = $("#gotoPage").val();
				pageno = currentpage;
				pagesize = pagesize;
				$("#gotoPage").val(pageno);
				Runprogress();
			} else {
				currentpage = $("#gotoPage").val();
				pageno = parseInt(currentpage) + 1;
				//pagesize = $("#items").val();
				pagesize = pagesize;
				$("#gotoPage").val(pageno);
				Runprogress();
			}
		} else if (data == "last") {
				pageno = Math.ceil(parseFloat(result) / parseFloat(pagesize));
				//pagesize = $("#items").val();
				pagesize = pagesize ? pagesize: 10;
				$("#gotoPage").val(pageno);
				Runprogress();
		} else if (data == "first") {
			var Actpageno = Math.ceil(parseFloat(result) / parseFloat(pagesize));
			if (pageno > Actpageno) {
				$.alert({
					title: 'Recon',
					content: "Page number is greate than total number of page",
					type: 'red',
				});
				pageno = 1;
				$("#gotoPage").val(pageno);
				return;
			}
			pageno = 1;
			//pagesize = $("#items").val();
			pagesize = pagesize;
			$("#gotoPage").val(pageno);
			Runprogress();
		}
		else {
			currentpage = $("#gotoPage").val();
			if (currentpage > 1){
				pageno = currentpage - 1;
				pagesize = pagesize;
				//pagesize = $("#items").val();
				$("#gotoPage").val(pageno);
				Runprogress();
			}
		}
	}

