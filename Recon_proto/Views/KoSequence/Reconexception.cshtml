					var result = JSON.parse(response);
					if(result.outparam[0].out_result == 2) {
						item.set("Rp_user", result.Table[0]["user_code"]);
						item.set("Rp_lock", result.Table[0]["active_status"]);
						var row = grid1.tbody.find("tr[data-uid='" + item.uid + "']");
						row.addClass("row-locked");
					}
				}
			});
		});
	}
	
	function gridlist() {
		if ($("#reconname").val() != '') {
			sessionStorage.setItem("reconcode", $("#reconname").val());
			sessionStorage.setItem("reconname", $("#reconname :selected").text());
			setcon();
			reconfieldinfo();
			addcss();
		}
	}

	function reconfieldinfo() {
		var jsondata = {};
		jsondata.in_recon_code = $("#reconname").val();
		jsondata.in_user_code = sessionStorage.getItem("usrname");
		$.ajax({
			type: "POST",
			url: '../KoSequence/reconfieldinfo',
			dataType: 'json',
			async: false,
			data: JSON.stringify(jsondata),
			contentType: 'application/json; charset=utf-8',
			success: function (response) {
				var res = JSON.parse(response);
				$('#report_code').val(res[0].report_code);
				$('#reporttemplate_code').val(res[0].reporttemplate_code);
				$('#reporttemplateresultset_code').val(res[0].reporttemplateresultset_code);
				$('#position_tran_gid').val(res[0].position_tran_gid);
				$('#position_tranbrkp_gid').val(res[0].position_tranbrkp_gid);
			}
		});
		grid_tempfilter([]);
		var jsondata = {};
		jsondata.in_reporttemplate_code = $("#reporttemplate_code").val();
		jsondata.in_reporttemplateresultset_code = $('#reporttemplateresultset_code').val();
		jsondata.in_recon_code = $("#reconname").val();
		jsondata.in_report_code = "";
		jsondata.in_action_by = sessionStorage.getItem("usrname");
		ReporType = "Standard";
		reconCode = $("#reconname").val();
		templateCode = "";
		report_permission = reportpermissionscreen(reconCode, templateCode);
		$.ajax({
			type: "POST",
			url: '../Reports/reporttemplatefetch',
			dataType: 'json',
			async: false,
			data: JSON.stringify(jsondata),
			contentType: 'application/json; charset=utf-8',
			success: function (response) {
				if (response != " " && response != null && response != "{}" && response != "[]") {
					var res = JSON.parse(response);
					if(res.Table.length > 0) {
						$("#reporttemplate_code").val(res.Table[0].reporttemplate_code);
						$("#txtmode").val(getlocalStorage('btn_clk_val'));
						$("#txtstatus").val("Active");
						$("#file_name").val(res.Table[0].file_name);
						$("#reporttemplate_gid").val(res.Table[0].reporttemplate_gid);
						$("#rt_name").val(res.Table[0].reporttemplate_name);
						$("#cmbreporttype").val(res.Table[0].report_code);
						//$("#reconname").val(res.Table[0].recon_code);
						 gridcopy = res.Table1;
						 res.Table1.forEach(function (item, index) {
							if (index !== res.Table1.length - 1) {
								item.isLastRow = false;
							} else {
								item.isLastRow = true;
							}
						 });
						grid_tempfilter(gridcopy);
						$("#cmbreporttype").val(res.Table[0].report_code);
					}
				}
				else {
					grid_tempfilter([])
				}
			},
			error: function (er) {
				alert(er)
				console.log(er)
			}
		});
	}	
</script>