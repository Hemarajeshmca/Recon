@model Recon_proto.Controllers.PreprocessController.partialfetchmodel
@using Newtonsoft.Json.Linq
@{
	JObject json = null;

	if (!string.IsNullOrEmpty(Model?.partialdata))
	{
		json = JObject.Parse(Model.partialdata);
	}
	var header = json?["header"]?[0];
	var lookupexp = json?["lookupexp"];
}
<div class="accordion-wrapper">
	<div class="accordion" id="headingexpressionlookup">
		<input type="checkbox" name="radio-a" id="check15" checked style="display:none">
		<label class="accordion-label" for="check15">&nbsp;&nbsp;&nbsp;Lookup Expression</label>
		<div id="headingexpressionlookup" class="accordion-content">
			<div class="accordion-body" style="padding-left:15px;">
				<div class="row" style="padding-bottom:2px">
					<div class="col-sm-6" style="margin-top:-17px;">
						<label class="form-label" for="">Lookup Dataset &nbsp&nbsp;<span style="font-size: 12px;color: red;font-weight: bold;">*</span></label>
						<select id="cmblookupdataset1" class="form-select form-control">
						</select>
					</div>
				</div>
				<div class="row" style="margin-bottom:5px;">
					<div class="col-xs-12" style="margin-top:5px;">
						<div id="grid_expression1">
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
<script>	
	$(document).ready(function () {
		var data1 = @Html.Raw(lookupexp?.ToString() ?? "[]")
		grid_expression1(data1);
	});
	var reconcode = sessionStorage.getItem("reconcode");;
	var in_user_code = sessionStorage.getItem("usrname");
	var selectedValue = '@(header?["lookup_dataset_code"]?.ToString() ?? "")';
	$.ajax({
		type: "POST",
		url: '../Preprocess/Preprocessdatasetfetch',
		dataType: 'json',
		async: false,
		data: JSON.stringify({ in_recon_code: reconcode, in_user_code: in_user_code }),
		contentType: 'application/json; charset=utf-8',
		success: function (response) {
			var res = JSON.parse(response);
			$("#cmblookupdataset1").empty();
			$("#cmblookupdataset1").append($('<option>', {
				value: "",
				text: "  Select  "
			}));
			$.each(res, function (index, item) {
				if (item.dataset_type == "L") {
					$("#cmblookupdataset1").append($('<option>', {
						value: item.dataset_code,
						text: item.dataset_name
					}));
				}
			});
			$("#cmblookupdataset1").val(selectedValue);
		}
	});
	function grid_expression1(data) {
		var preprocessexp_update_field_list = "";
		$("#grid_expression1").kendoGrid({
			dataSource: {
				data: data,
				pageSize: 5,
				sort: [{ field: "recorder_seqno", dir: "asc" }],
				schema: {
					model: {
						fields: {
							preprocessexp_gid: { type: "string", defaultValue: "0" },
							preprocess_code: { type: "string" },
							preprocessexp_sno: { type: "string" },
							preprocessexp_update_field: { type: "string" },
							preprocess_expression: { type: "string" },
							active_status: { type: "string" },
							active_status_desc: { type: "string" }
						}
					}
				}
			},
			toolbar: "<a onclick=addexp1()  href='javascript:void(0)' ><span class='fa fa-plus' style='color:white'></span></a>",
			height: 185,
			groupable: false,
			dataBound: function (e) {
				resultData = e.sender._data;
				var rows = $('#grid_expression1').data('kendoGrid').tbody.children();
				setColor(rows, resultData);
				if ($("#txtmode").val() == "View") {
					$(".k-grid-save").hide();
					$(".k-grid-delete").hide();
					$(".k-grid-add").hide();
				}
			},
			sortable: false,
			selectable: true,
			filterable: false,
			navigatable: true,
			resizable: true,
			pageable: true,
			pageable: {
				refresh: false,
				pageSizes: true,
				buttonCount: 5
			},
			columns: [{
				command: [
					{
						name: "save",
						id: "Save",
						template: "<a href=''onclick='savelookupexp()' class='k-grid-save' data-bs-toggle='modal' ><img src = '../Assets/images/topsave.png' style='width:18%;'></a>&nbsp;&nbsp;&nbsp;",
					},
					{
						name: "Delete",
						id: "Delete",
						template: function (dataItem) {
							// Check your condition here to determine whether to show or hide the delete button
							if ($("#txtmode").val() == "View") {
								return ""; // Return empty string to hide the delete button
							} else {
								return "<a href='' onclick='myDeleteJslookupexp()'  data-bs-toggle='modal'><img src = '../Assets/images/del.png'></a>&nbsp;&nbsp;&nbsp;"
							}
						}
					},
				], title: "Action&nbsp;", width: "20px",
			},
			{
				field: "preprocessexp_gid",
				title: "preprocessexp_gid",
				hidden: true,
			},
			{
				field: "preprocess_code",
				title: "preprocess_code",
				width: 100,
				hidden: true,
			},
			{
				field: "preprocessexp_update_field_code",
				title: "preprocessexp_update_field",
				width: 100,
				hidden: true,
			},
			{
				field: "preprocessexp_sno",
				title: "Seq No.",
				width: 30,
				attributes: { style: "text-align: right;" },
				editor: function (container, options) {
					item_rate(container, options.field, '9', '3');
				},
			},
			{
				field: "preprocessexp_update_field",
				title: "Lookup Field",
				width: 40,
				editor: function (container, options) {
					combo_editor_exp1(container, "cmb_" + options.field, eval(options.field + "_list"), options.field, "preprocessexp_update_field_code", "grid_expression1")
				},
			},
			{
				field: "preprocess_expression",
				title: "Expression",
				width: 150,
			},
			{
				field: "active_status",
				title: "Status",
				hidden: true
			},
			{
				field: "active_status_desc",
				title: "Status",
				width: 80,
				hidden: true
			}],
			editable: true,
		});
	}
	function addexp1() {
		if ($("#txtpreprocesscode").val() != '') {
			if ($("#cmblookupdataset1").val() == "") {
				$.alert({
					title: 'Recon',
					content: "Lookup Dataset cannot be empty",
					type: 'green',
				});
				return;
			}
			var grid = $("#grid_expression1").data("kendoGrid");
			var dataSource = grid.dataSource;
			var max = 0;
			var lastSeqNo = grid.dataSource._data.length;
			for (var i = 0; i < grid.dataSource._data.length; i++) {
				if (parseInt(grid.dataSource._data[i].preprocessexp_sno) > parseInt(max)) {
					max = grid.dataSource._data[i].preprocessexp_sno;
				}
			}
			var newSeqNo = parseInt(max) + 1;

			// Add a new row with the incremented sequence number
			dataSource.add({ preprocessexp_sno: newSeqNo, preprocessexp_gid: 0,preprocessexp_update_field: "",preprocess_expression: "" });
			var lastRow = grid.tbody.children().last();
			grid.content.scrollTop(lastRow.position().top);
		} else {
			saveheader();
		}
	}
	function combo_editor_exp1(container, cmbid, datasource, datafield, code_datafield, grid_id) {
		var arr1 = [];	
		var datasetcode = $("#cmblookupdataset1").val();
		var in_user_code = sessionStorage.getItem("usrname");
		$.ajax({
			type: "POST",
			url: '../Recon/Datasetfieldlist',
			dataType: 'json',
			async: false,
			data: JSON.stringify({ datasetCode: datasetcode, in_user_code: in_user_code }),
			contentType: 'application/json; charset=utf-8',
			success: function (response) {
				if (response != null) {
					var result = JSON.parse(response);
					for (i = 0; result.DataSet.length > i; i++) {
							var list1 = {};
							list1.code = result.DataSet[i].dataset_table_field;
							list1.desc = result.DataSet[i].field_name;
							arr1.push(list1);
					}
				}
			}
		});
		
		$('<input  id="' + cmbid + '" data-text-field="desc" data-value-field="desc" data-bind="value:' + datafield + '" name ="' + datafield + '"/>').appendTo(container).kendoComboBox({
			autoBind: false,
			filter: "contains",
			dataSource: arr1,
			change: function (e) {
				var cmb_value = this.value();
				if (cmb_value && this.selectedIndex == -1) {
					this.value("");
				}
				//else{FF
				var cmb_var = $("#" + grid_id).data("kendoGrid");
				var selectedItem = cmb_var.dataItem(cmb_var.select());
				var combobox_data = $("#" + cmbid).data("kendoComboBox");
				if (combobox_data != undefined && combobox_data.selectedIndex == -1) {
					selectedItem[datafield] = "";
					selectedItem[code_datafield] = "";
				}
				else {
					selectedItem[datafield] = combobox_data.dataItem(combobox_data.selectedIndex).desc;
					selectedItem[code_datafield] = combobox_data.dataItem(combobox_data.selectedIndex).code;
				}
			}
		});

		$("<span class='k-invalid-msg' data-for='" + datafield + "'></span>").appendTo(container);
	}
	function savelookupexp() {
		try {			
			var grid = $("#grid_expression1").data("kendoGrid");
			var model = grid.dataItem($(event.target).closest("tr"));
			var in_preprocess_code = $("#txtpreprocesscode").val();
			var in_preprocessexp_sno = model.preprocessexp_sno;
			var in_preprocessexp_on = "LOOKUP";
			var in_preprocessexp_update_field = model.preprocessexp_update_field_code;
			var in_preprocess_expression = model.preprocess_expression;
			
			var action = "INSERT";
			var action_by = sessionStorage.getItem("usrname");
			var in_preprocessexp_gid = model.preprocessexp_gid;
			if (in_preprocessexp_gid == "0") {
				in_preprocessexp_gid = 0;
				action = "INSERT"
			} else {
				in_preprocessexp_gid = model.preprocessexp_gid
				action = "UPDATE"
			}
			var status = "Y"
			$.ajax({
				type: "POST",
				url: '../Preprocess/preprocessexp',
				dataType: 'json',
				data: JSON.stringify({
					in_preprocessexp_gid: in_preprocessexp_gid, in_preprocess_code: in_preprocess_code,
					in_preprocessexp_sno: in_preprocessexp_sno, in_preprocessexp_on: in_preprocessexp_on,in_preprocessexp_update_field: in_preprocessexp_update_field,in_preprocess_expression: in_preprocess_expression,
					in_action: action, in_user_code: action_by, in_active_status: status
				}),
				contentType: 'application/json; charset=utf-8',
				success: function (response) {
					if (response.out_result == "1") {
						$.alert({
							title: 'Recon',
							content: response.out_msg,
							type: 'green',
						});
						preprocessfetch($("#txtpreprocesscode").val());
					} else {
						$.alert({
							title: 'Recon',
							content: response.out_msg,
							type: 'red',
						});
					}
				},
			});
		}
		catch (e) {
			console.log(e)
		}
	}
	function myDeleteJslookupexp() {
		var grid = $("#grid_expression1").data("kendoGrid");		
		var model = grid.dataItem($(event.target).closest("tr"));
		var in_preprocessexp_gid = parseInt(model.preprocessexp_gid);
		if (in_preprocessexp_gid == 0) {
			grid.dataSource.remove(model);
		} 
		else {
			$.confirm({
				icon: 'fa fa-warning',
				title: 'Recon',
				autoClose: 'cancel|10000',
				theme: 'dark',
				animationSpeed: 700,
				content: 'Are you sure do you want to delete this record!',
				type: 'orange',
				buttons: {
					confirm: function () {
						var in_preprocess_code = "";
						var in_preprocessexp_sno = 0;
						var in_preprocessexp_on = "";
						var in_preprocessexp_update_field = "";
						var in_preprocess_expression = "";
						var action = "DELETE";
						var action_by = sessionStorage.getItem("usrname");
						var status = ""
						$.ajax({
							type: "POST",
							url: '../Preprocess/preprocessexp',
							dataType: 'json',
							data: JSON.stringify({
									in_preprocessexp_gid: in_preprocessexp_gid, in_preprocess_code: in_preprocess_code,
									in_preprocessexp_sno: in_preprocessexp_sno, in_preprocessexp_on: in_preprocessexp_on,in_preprocessexp_update_field: in_preprocessexp_update_field,
									in_preprocess_expression: in_preprocess_expression,
									in_action: action, in_user_code: action_by, in_active_status: status
							}),
							contentType: 'application/json; charset=utf-8',
							success: function (response) {
							if (response.out_result == "1") {
								$.alert({
									icon: 'fa fa-success',
									title: 'Recon',
									theme: 'dark',
									content: response.out_msg,
									type: 'green',
									animationSpeed: 700,
								});
								preprocessfetch($("#txtpreprocesscode").val());
							} 
							else {
								$.alert({
									title: 'Recon',
									content: response.out_msg,
									type: 'red',
								});
							}
						}
					})
				},
				cancel: function () {
					$.alert({
						icon: 'fa fa-success',
						title: 'Recon',
						theme: 'dark',
						content: 'Delete Canceled.!',
						type: 'blue',
						animationSpeed: 700,
					});
				},
				}
			});
		}
	}
</script>