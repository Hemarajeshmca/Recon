		} else {
			$("#lookupgrid").hide();
			$("#Cmblookupdatasetfield").prop('disabled', false);
			$("#Cmbreconfieldpre1").prop('disabled', false);
			$("#luprfield").show();
			$("#uprfield").show();
			$("#rflag").show();
		}
	}
