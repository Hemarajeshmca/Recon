<!Doctype html>
<html>
<head>
    <title></title>

    <style>

        .k-state-active {
            display: block !important
        }


        .delete-icon {
            cursor: pointer;
            color: #dc3545;
            font-size: 22px; /* bigger size */
            font-weight: bold;
            padding: 4px 8px; /* make it easy to click */
            border-radius: 4px;
            background-color: #f8d7da; /* light red background */
            transition: 0.2s;
        }

            .delete-icon:hover {
                background-color: #dc3545;
                color: #fff;
            }

        .subtle-close {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(0,0,0,0.2); /* subtle background */
            border: none;
            color: rgba(255,255,255,0.7); /* semi-transparent white */
            font-size: 24px;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .subtle-close:hover {
                background: rgba(0,0,0,0.5);
                color: white;
                transform: scale(1.1);
            }

        .save_btn {
            background: #175650;
            border-color: #175650;
            cursor: pointer;
            color: white;
            min-width: 8%;
        }

        .cancel_btn {
            background: #ff0000;
            border-color: #ff0000;
            cursor: pointer;
            color: white;
            min-width: 8%;
        }

        #ticket_dataset .ticket-link {
            color: #007bff;
            cursor: pointer;
            font-weight: bold;
            text-decoration: none;
        }

         #ticket_dataset .ticket-link:hover {
                text-decoration: underline;
            }

        .tborder1 {
            border: 1px solid #d5d6d7;
            padding: 10px;
            border-radius: 10px;
            margin-top: -10px;
            overflow-y: scroll;
            height: 122px;
            overflow-x: hidden;
            width: 98%;
            margin-left: 14px;
            margin-bottom: 31px;
        }

        .k-state-active {
            display: block !important
        }

       #ticket_dataset .k-grid-content {
            height: 280px !important;
        }

        #attachmentsInput::-webkit-file-upload-button {
            background-color: #175650;
            color: white;
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
        }

        /* Standard (non-webkit) */
        #attachmentsInput::file-selector-button {
            background-color: #175650;
            color: white;
            padding: 8px 16px;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            font-weight: bold;
        }

        #attach_dataset .k-grid-content {
            height: 226px !important;
        }

        .content-area {
            display: none;
            margin-top: 15px;
        }

        #ticket_dataset.k-grid.k-widget {
            height: 162px !important;
        }

        .k-popup,
        .k-animation-container {
            z-index: 999999 !important;
            position: absolute !important;
        }

        #ticketModal {
            overflow: visible !important;
        }

      
    </style>

</head>
