<script>
           $(document).ready(function () {              
        // Default on page load → Assigned
        $('#navs-pills-top-list').tab('show');
        $("#queryErrortkttype").text("");
        $("#queryErrorpriority").text("");
        $("#queryErrorscreen").text("");
        $("#queryErrorrecname").text("");
        $("#queryErrorreport").text("");
        $("#queryErrorsub").text("");
        $("#queryErrormsg").text("");
        $("#queryErrorasto").text("");
        $('input[name="options"]').change(function () {

            if ($('#options1').is(':checked')) {
                // Assigned → Tickets List tab
                $('button[data-bs-target="#navs-pills-top-list"]').tab('show');                
            }

            if ($('#options2').is(':checked')) {
                // New → Raise Ticket tab                
                    $('button[data-bs-target="#navs-pills-top-new"]').show();
                    $('button[data-bs-target="#navs-pills-top-new"]').tab('show');
                    $("#txtTicketNo").val("New");
                $("#queryErrortkttype").text("");
                $("#queryErrorpriority").text("");
                $("#queryErrorscreen").text("");
                $("#queryErrorrecname").text("");
                $("#queryErrorreport").text("");
                $("#queryErrorsub").text("");
                $("#queryErrormsg").text("");
                $("#queryErrorasto").text("");
        $('button[data-bs-target="#navs-pills-top-new"]').show();
        $('button[data-bs-target="#navs-pills-top-new"]').tab('show');
        $('button[data-bs-target="#navs-pills-top-new"]').text("Raise Ticket");
        grid_edit = 'N';
        $("#cmbqueue").val("TKT_STATUS_NEW").trigger("change").prop("disabled", true);
        //$("#cmbqueue").prop("disabled", true);
       // $("#cmbassign1").prop("disabled", true);
        $("#cmbtype, #cmbpriority, #cmbStatus, #txtSubject").prop("disabled", false);
        setCurrentDateTime();
        $("#txtSubject").val("");        
        $("#cmbpriority").val("");
        $("#cmbStatus").val("");
        $("#emailBody").val("");
        $("#cmbtype").val("");
        $("#screenname").val("");
        $("#recname").val("").prop("disabled", true);
        $("#report").val("").prop("disabled", true);
        $(".save_btn").show();
        $(".update_btn").hide();
        $(".tborder1").hide();
        $("#textareaRow").show();

        $("#cmbassign1").val("admin");
        if (role_code != "RC006" && role_code != "RC028") {
            $("#cmbassign1").prop("disabled", true);
        }
            }
        });
    });
     var userMap = {};
    var canAdd = '';
    var canEdit = '';
    var canDelete = '';
    var canProcess = '';
    var screen_code = '';
    var role_code = '';
    var Is_ticketuser = '';
    var last_insert = '';
    var grid_edit = 'N';
    var raiser_code = '';
    var insert_by = '';
    let attachmentList = [];
    var selectedMenuCode = '';
    var selectedMenuName = '';
    var selectedReconCode = '';
    var selectedReconName = '';
    var selectedReportCode = '';
    var selectedReportName = '';
    var selectedTickets = [];
    var isNewTicket = false;
    // $("#navhead").text("Support Ticketing System");
    $("#ticketModalLabel").text("Support Ticketing System");
    $(document).ready(function () {
        $('#ticketModal').on('shown.bs.modal', function () {
            $.fn.modal.Constructor.prototype._enforceFocus = function () { };             
        });
       
        $('button[data-bs-target="#navs-pills-top-attach"]').hide();
        $('button[data-bs-target="#navs-pills-top-new"]').hide();


        $('button[data-bs-target="#navs-pills-top-list"]').on('shown.bs.tab', function () {
            $('button[data-bs-target="#navs-pills-top-new"]').hide();
            $('button[data-bs-target="#navs-pills-top-attach"]').hide();
            $('#options1').prop('checked', true);             
            ticketlist();
        });

        $('button[data-bs-target="#navs-pills-top-attach"]').on('shown.bs.tab', function () {
            $('button[data-bs-target="#navs-pills-top-attach"]').show();
        });
         
        var txtusrname = sessionStorage.getItem("recon_userdetail");
        screen_code = rolevalidatescreen('tkt_sys');
        role_code = sessionStorage.getItem("rolecode");
        if (screen_code && screen_code.length > 0) {
            var permissions = screen_code[0];
            canAdd = permissions.add || 'N';
            canEdit = permissions.edit || 'N';
            canDelete = permissions.delete || 'N';
            canProcess = permissions.process || 'N';
        } else {
            console.warn("No permissions found for screen:", screen_code);
        }
         if (canAdd == 'N') {
                document.getElementById("div_add").style.display = "none";
            }

        if (role_code == "RC027") {
           
            document.getElementById("lblassign").style.display = "none";
            document.getElementById("bthassign").style.display = "none";
            document.getElementById("asgndto").style.display = "none";
            document.getElementById("lblremarks").style.display = "none";
            document.getElementById("download").style.display = "none";
            $("#options1").closest("label").hide();
            $("#options2").closest("label").hide();
            $("#div_add").show();
            Is_ticketuser = 'User';
            // const div = document.getElementById("cmbqueue");
            // div.style.pointerEvents = "none";
            // div.style.opacity = "0.5";
        }
        else if (role_code == "RC006") {
            Is_ticketuser = 'Admin';
            // document.getElementById("raiser_div").style.display = "block";
            const div = document.getElementById("cmbqueue");
            div.style.pointerEvents = "auto";
            div.style.opacity = "1";            
        }
        else if (role_code == "RC010") {
            Is_ticketuser = 'Support';
            // document.getElementById("raiser_div").style.display = "block";
            const div = document.getElementById("cmbqueue");
            div.style.pointerEvents = "auto";
            div.style.opacity = "1";
        }
        else if (role_code == "RC028") {
            Is_ticketuser = 'Ticket Support';
            // document.getElementById("raiser_div").style.display = "block";
            const div = document.getElementById("cmbqueue");
            document.getElementById("lblassign").style.display = "none";
            document.getElementById("bthassign").style.display = "none";
            document.getElementById("asgndto").style.display = "none";
            document.getElementById("lblremarks").style.display = "none";
            document.getElementById("download").style.display = "none";
             $("#options1").closest("label").hide();
             $("#options2").closest("label").hide();
             $("#div_add").show();
            div.style.pointerEvents = "auto";
            div.style.opacity = "1";
        }

        ticketlist();
        var lvl1 = sessionStorage.getItem("level1txt");
        var lvl2 = sessionStorage.getItem("level2txt");
        var lvl3 = sessionStorage.getItem("level3txt");
        var context_code = sessionStorage.getItem("level3");
        var usercode = sessionStorage.getItem("usrname");

        console.log("Session values:", lvl1, lvl2, lvl3, usercode);

        // build combined text if they exist
        if (lvl1 || lvl2 || lvl3) {
            var contextVal = [lvl1, lvl2, lvl3].filter(Boolean).join(" / ");
            $("#txtcontext").val(contextVal);
            $("#tabtxtcontext").val(contextVal);
        }
       

        // Menu
        $.ajax({
            type: "POST",
            url: '../Admin/getmenu',
            dataType: 'json',
            data: JSON.stringify({user_code:usercode }),
            contentType: 'application/json; charset=utf-8',
            success: function (response) {        
            var data = JSON.parse(response);
                $("#screenname").empty();
                $("#screenname").append($('<option>', {
                    value: "",
                    text: "  Select  "
                }));
                   $.each(data.SubMenu, function (index, item) {
                    $("#screenname").append($('<option>', {
                        value: item.menu_gid,
                        text: item.menu_name
                    }));
                });
                $("#screenname").on("change", function () {
                    selectedMenuCode = $(this).val();
                    selectedMenuName = $("#screenname option:selected").text();
                    console.log("Selected Menu Code:", selectedMenuCode);
                    console.log("Selected Menu Name:", selectedMenuName);
                   if (selectedMenuName.trim() === "Report Generation") {
                        $("#recname").prop("disabled", false);
                        reconname();
                    } else {
                        $("#recname").prop("disabled", true).val("");
                    }
                });
            }
        });

         $("#recname").on("change", function () {
                    selectedReconCode = $(this).val();
                    selectedReconName = $("#recname option:selected").text();
                    $("#report").prop("disabled", false);
                    reportlist(selectedReconCode);
                    console.log("Selected Recon Code:", selectedReconCode);
                    console.log("Selected Recon Name:", selectedReconName);
           });

        $("#report").on("change", function () {
                    selectedReportCode = $(this).val();
                    selectedReportName = $("#report option:selected").text();
                      console.log("Selected Recon Code:", selectedReportCode);
                    console.log("Selected Recon Name:", selectedReportName);
                });

        

        // Assigned User
        $.ajax({
            type: "POST",
            url: '../Ticket/assigedUsers',
            dataType: 'json',
            data: JSON.stringify({in_context_code:context_code,  in_lang_code: '', in_ip_addr: '' }),
            contentType: 'application/json; charset=utf-8',
            success: function (response) {
                $("#cmbassign").empty();
                $("#cmbassign").append($('<option>', {
                    value: "",
                    text: "  Select  "
                }));
                $.each(response, function (index, item) {
                    //if (item.role_code === "RC028") {
                    userMap[item.user_name.trim()] = item.user_code.trim();
                        $("#cmbassign").append($('<option>', {
                            value: item.user_code,
                            text: item.user_name
                        }));
