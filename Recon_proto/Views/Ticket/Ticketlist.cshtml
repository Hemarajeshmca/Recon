    function updateAttachGrid() {       
          var username = sessionStorage.getItem("username");
         
        var grid = $("#attach_dataset").data("kendoGrid");

        // Always initialize the grid (even if empty)
        if (!grid) {
            $("#attach_dataset").kendoGrid({
                dataSource: {
                    data: attachmentList, // even if empty
                    pageSize: 15
                },
                height: 258,
                groupable: false,
                sortable: true,
                selectable: true,
                filterable: true,
                navigatable: true,
                resizable: false,
                noRecords: {
                    template: "<div style='padding:10px; text-align:center;'>No attachments found.</div>"
                },
                columns: [
                    { field: "insert_date", title: "Attachment Date", width: 150, template: function (dataItem) {
                        return formatDateDDMMYYYYHHMMSS(dataItem.insert_date);
                    } },
                    { field: "file_name", title: "File Name", width: 330 },
                    { field: "user_name", title: "Uploaded By", width: 185 },
                    { field: "master_name", title: "Status",hidden:true },
                    {
                        field: "Action",
                        title: "Action",
                        width: 80,
                        encoded: false,
                        sortable: false,
                        filterable: false,
                        template: function (dataItem) {
                            let deleteIcon = "";
                            console.log("attusercode: ", username);
                            if (dataItem.user_name === username) {
                            deleteIcon = `
                                <a href='javascript:void(0)' title='Delete'>
                                    <img src='../Assets/images/del.png' style='margin-left:17px;' onclick='DelAttachment($(this))'>
                                </a>`;
                        } else {
                            deleteIcon = `<span style="display:inline-block; width:24px; margin-left:10px;"></span>`;
                        }
                            if (dataItem.is_new) {
                                // Show only Delete for new files
                                return `
                                                <div style="display:flex;justify-content:center;align-items:center;gap:10px;padding-left: 29px;">
                                                    <a href='javascript:void(0)' title='' onclick='' style="display:none">
                                                        <i class='fa fa-download' style='color:blue;'></i>
                                                    </a>
                                                  ${deleteIcon}
                                                </div>`;
                            } else {
                                // Show Download + Delete for DB files
                                   return `
                                            <div style='text-align:center'>
                                                <a href='javascript:void(0)'
                                                   title='Download'
                                                   onclick='DownloadAttachment("${dataItem.attachment_gid}", "${dataItem.file_name}")'>
                                                    <i class='fa fa-download' style='color:blue;'></i>
                                                </a>
                                                ${deleteIcon}
                                            </div>`;

                            }
                        }
                    },
                    { field: "attachment_gid", hidden: true },
                    { field: "ticket_gid", hidden: true }
                ],
                 pageable: {
                    refresh: false,
                    pageSizes: [10, 15, 20, 25, 50],
                    buttonCount: 5
                },
                editable: false
            });
        } else {
            // Update data when grid already exists
            grid.dataSource.data(attachmentList);
            grid.refresh();
        }
    }


    // ✅ Delete attachment (both new and DB)


    function DelAttachment(el) {
        const grid = $("#attach_dataset").data("kendoGrid");
        const row = el.closest("tr");
        const dataItem = grid.dataItem(row);


        $.confirm({
            icon: 'fa fa-warning',
            title: 'Recon',
            autoClose: 'cancel|10000',
            theme: 'dark',
            animationSpeed: 700,
            content: 'Are you sure you want to delete this Ticket?',
            type: 'orange',
            buttons: {
                confirm: function () {
                    // If it's a new (unsaved) attachment — just remove locally
                    if (dataItem.is_new) {
                        attachmentList = attachmentList.filter(a => a.file_name !== dataItem.file_name);
                        updateAttachGrid();
                        return;
                    }

                    var usercode = sessionStorage.getItem("usrname");
                    var data = {
                        in_action: 'DELETE',
                        ticket_gid: parseInt(dataItem.ticket_gid),
                        attachment_gid: parseInt(dataItem.attachment_gid),
                        in_user: usercode,
                        in_ip_addr: ''
                    };

                    $.ajax({
                        type: "POST",
                        url: '../Ticket/DeleteAttachment',
                        dataType: 'json',
                        data: JSON.stringify(data),
                        contentType: 'application/json; charset=utf-8',
                        success: function (response) {
                            console.log("DeleteAttachment Response:", response);
                            if (response.data) {
                                const parsed = JSON.parse(response.data);
                                const resultData = parsed[0];
                                if (resultData.result === 1) {
                                    $.alert({
                                        icon: 'fa fa-check',
                                        title: 'Recon',
                                        theme: 'dark',
                                        content: resultData.message,
                                        type: 'green',
                                        animationSpeed: 700,
                                    });
                                    attachlist(parseInt(dataItem.ticket_gid));
                                }
                                else {
                                    $.alert({
                                        title: "Recon",
                                        content: resultData.message,
                                        type: "red"
                                    });
                                }

                            } else {
                                $.alert({
                                    title: "Ticket System",
                                    content: resultData.message || "Unexpected server error",
                                    type: "red"
                                });
                            }
                        },
                        error: function (er) {
                            console.log("Error deleting attachment:", er);
                            $.alert({
                                title: "Error",
                                content: "Error deleting attachment.",
                                type: "red"
                            });
                        }
                    });

                },
                cancel: function () {
                    $.alert({
                        icon: 'fa fa-info',
                        title: 'Recon',
                        theme: 'dark',
                        content: 'Delete Canceled!',
                        type: 'blue',
                        animationSpeed: 700,
                    });
                }
            }
        });
    }



    // ✅ Download file from server
          function DownloadAttachment(attachment_gid, originalFileName) {
        if (!attachment_gid || attachment_gid === "0") {
            alert("File not yet uploaded to server.");
            return;
        }

        window.location.href =
            `../Ticket/DownloadAttachment?attachment_gid=${attachment_gid}&originalFileName=${encodeURIComponent(originalFileName)}`;
    }



