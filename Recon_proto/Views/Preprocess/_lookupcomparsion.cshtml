	}
	function addRowlookupcomparsion() {
		var grid = $("#grid_lookupcomparsion").data("kendoGrid");
		var dataSource = grid.dataSource;
		var max = 0;
		// Get the last sequence number and increment it
		var lastSeqNo = grid.dataSource._data.length;
		for (var i = 0; i < grid.dataSource._data.length; i++) {
			if (parseInt(grid.dataSource._data[i].rec_seqno) > parseInt(max)) {
				max = grid.dataSource._data[i].rec_seqno;
			}
		}
		var newSeqNo = parseInt(max) + 1;
		// Add a new row with the incremented sequence number
		dataSource.add({ rec_seqno: newSeqNo, preprocessdsupdate_gid: 0,value_flag: 'N',reverse_update_flag: 'N' });
		var lastRow = grid.tbody.children().last();
		grid.content.scrollTop(lastRow.position().top);
	}
	function savelookupcomparsion() {
		var grid = $("#grid_lookupcomparsion").data("kendoGrid");
		var model = grid.dataItem($(event.target).closest("tr"));
		var in_txtpreprocesscode = $("#txtpreprocesscode").val();
		var in_rec_seqno = model.rec_seqno;
		var comparison_field = model.comparison_field;
		var source_field = model.source_field;
		var reverse_update_flag = model.reverse_update_flag;
		var value_flag = model.value_flag;
		if (value_flag == "Y" && reverse_update_flag == 'N')
		{
			if(model.comparison_field_desc != ''){
				var comparison_field = model.comparison_field_desc;
			}else {
				var comparison_field = model.comparison_field_input;
			}
		} else {
			if(model.comparison_field == '')
			{
				$.alert({
					title: 'Recon',
					content: 'Lookup Return Field  value not selected',
					type: 'red',
				});
				return false;
			}
		}
		if (reverse_update_flag == "Y" && value_flag == 'Y')
		{
			if(model.source_field_desc != ''){
				var source_field = model.source_field_desc;
			}else {
				var source_field = model.source_field_input;
			}
		} else {
			if(model.source_field =='')
			{
				$.alert({
					title: 'Recon',
					content: 'Update Recon Field  value not selected',
					type: 'red',
				});
				return false;
			}
		}
		var action = "";
		var action_by = sessionStorage.getItem("usrname");
		var preprocessdsupdate_gid = model.preprocessdsupdate_gid;
		if (preprocessdsupdate_gid == "0") {
			preprocessdsupdate_gid = 0;
			action = "INSERT"
		} else {
			action = "UPDATE"
		}
		var status = 'Y';
		$.ajax({
			type: "POST",
			url: '../Preprocess/lookupcomparsionsave',
			dataType: 'json',
			data: JSON.stringify({
				in_preprocessdsupdate_gid: preprocessdsupdate_gid, in_preprocess_code: in_txtpreprocesscode, in_rec_seqno: in_rec_seqno,
				in_source_field: source_field,in_value_flag: value_flag,
				in_comparison_field: comparison_field, in_action: action, in_user_code: action_by, in_active_status: status,reverse_update_flag:reverse_update_flag
			}),
			contentType: 'application/json; charset=utf-8',
			success: function (response) {
				if (response != null) {
					$.alert({
						title: 'Recon',
						content: response.out_msg,
						type: 'green',
					});
					preprocessfetch($("#txtpreprocesscode").val());
				}
				else {
				}
			},
			error: function (er) {
				alert(er)
				console.log(er)
			}
		});
	}
	function myDeleteJslookupcomprsion() {
		var grid = $("#grid_lookupcomparsion").data("kendoGrid");
		var model = grid.dataItem($(event.target).closest("tr"));
		var preprocessdsupdate_gid = parseInt(model.preprocessdsupdate_gid);
		if (preprocessdsupdate_gid == 0) {
			grid.dataSource.remove(model);
		} else {
			$.confirm({
				icon: 'fa fa-warning',
				title: 'Recon',
				autoClose: 'cancel|10000',
				theme: 'dark',
				animationSpeed: 700,
				content: 'Are you sure do you want to delete this record!',
				type: 'orange',
				buttons: {
					confirm: function () {
						var in_txtpreprocesscode = $("#txtpreprocesscode").val();
						var in_rec_seqno = model.rec_seqno;
						var comparison_field = model.comparison_field;
						var source_field = model.source_field;
						var action = "DELETE";
						var action_by = sessionStorage.getItem("usrname");
						var preprocessdsupdate_gid = model.preprocessdsupdate_gid;
						var status = 'Y';
						var reverse_update_flag = "";
						var value_flag ="";
						$.ajax({
							type: "POST",
							url: '../Preprocess/lookupcomparsionsave',
							dataType: 'json',
							data: JSON.stringify({
									in_preprocessdsupdate_gid: preprocessdsupdate_gid, in_preprocess_code: in_txtpreprocesscode, in_rec_seqno: in_rec_seqno,
									in_source_field: comparison_field,in_value_flag: value_flag,
									in_comparison_field: source_field, in_action: action, in_user_code: action_by, in_active_status: status,reverse_update_flag:reverse_update_flag
							}),
							contentType: 'application/json; charset=utf-8',
							success: function (response) {
								if (response != null) {
									$.alert({
										title: 'Recon',
										content: response.out_msg,
										type: 'green',
									});
									preprocessfetch($("#txtpreprocesscode").val());
								}
								else {
								}
							},
							error: function (er) {
								alert(er)
								console.log(er)
							}
						})
					},
					cancel: function () {
						$.alert({
							icon: 'fa fa-success',
							title: 'Recon',
							theme: 'dark',
							content: 'Delete Canceled.!',
							type: 'blue',
							animationSpeed: 700,
						});
					},
				}
			});
		}
	}
</script>


