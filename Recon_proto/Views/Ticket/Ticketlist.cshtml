        // Clear current list
        attachmentList = [];

        var data = {
            in_action: 'SELECT',
            in_ticket_gid: parseInt(ticketgid),
            in_attachment_gid: parseInt(ticketgid),
            file_name: '',
            in_user: usercode,
            in_ip_addr: ''
        };

        $.ajax({
            type: "POST",
            url: '../Ticket/AttachFetch',
            dataType: 'json',
            data: JSON.stringify(data),
            contentType: 'application/json; charset=utf-8',
            success: function (response) {
                var result = JSON.parse(response);

                if (result && Array.isArray(result)) {
                    attachmentList = result;
                }
                updateAttachGrid();
            },
            error: function (er) {
                console.log("Error loading attachments:", er);
            }
        });
    }


