    $(document).ready(function () {

        // ✅ Handle file upload selection
        $("#attachmentsInput").on("change", function () {
             var username = sessionStorage.getItem("username");
            var input = this;
            if (input.files.length === 0) {
                $("#btnattach").hide();
                return;
            }

            for (let i = 0; i < input.files.length; i++) {
                const file = input.files[i];

                // ✅ Fix syntax: use backticks and correct alert
                if (attachmentList.some(att => att.file_name === file.name)) {
                    alert(`File "${file.name}" already added.`);
                    continue;
                }                   

                const attachment = {
                    attachment_gid: 0,
                    ticket_gid: $("#ticket_gid").val(),
                    file_name: file.name,
                    insert_date:new Date(),
                    user_name:username,
                    fileObject: file,
                    is_new: true
                };

                attachmentList.push(attachment);
            }

            // ✅ Clear file input to allow re-selecting same file after delete
            $(input).val("");

            // ✅ Refresh grid
            updateAttachGrid();
            $("#btnattach").show();
        });
    });



