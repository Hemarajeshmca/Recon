<script>

	function clearTicketForm() {
		// Reset text inputs
		document.getElementById('txtTicketNo').value = "";
		document.getElementById('txtSubject').value = "";

		// Reset selects
		document.getElementById('cmbassign').value = "";
		document.getElementById('cmbPriority').value = "";
		document.getElementById('cmbStatus').value = "";

		// Reset textarea
		document.getElementById('emailBody').value = "";

		// Reset file input and attachment list
		const fileInput = document.getElementById('attachmentsInput');
		const fileDisplay = document.getElementById('fileNameDisplay');
		const listDiv = document.getElementById('attachmentsList');

		fileInput.value = "";
		fileDisplay.value = "No file chosen";
		listDiv.innerHTML = "";

		// Optionally, reset modal title
		$("#ticketModalLabel").text("Create New Ticket");

		// Re-enable fields if they were disabled
		$("#txtSubject, #cmbassign, #cmbPriority, #cmbStatus, #emailBody, #chooseFilesBtn").prop("disabled", false);
	}


	document.addEventListener("DOMContentLoaded", function () {
		const chooseBtn = document.getElementById('chooseFilesBtn');
		const fileInput = document.getElementById('attachmentsInput');
		const fileDisplay = document.getElementById('fileNameDisplay');
		const listDiv = document.getElementById('attachmentsList');

		chooseBtn.addEventListener('click', () => fileInput.click());

		fileInput.addEventListener('change', function () {
			const files = Array.from(this.files);
			fileDisplay.value = files.map(f => f.name).join(', ') || 'No file chosen';
			listDiv.innerHTML = '';

			files.forEach((file, index) => {
				const div = document.createElement('div');
				div.style.marginTop = "5px";
				div.style.display = "flex";
				div.style.alignItems = "center";
				div.style.gap = "10px";

				// File name as link for image preview
				if (file.type.startsWith('image/')) {
					const link = document.createElement('a');
					link.href = "#";
					link.textContent = file.name;
					link.style.color = "#0d6efd";
					link.style.textDecoration = "underline";
					link.addEventListener('click', function (event) {
						event.preventDefault();
						const previewImage = document.getElementById('previewImage');
						const modal = new bootstrap.Modal(document.getElementById('imagePreviewModal'));
						const reader = new FileReader();
						reader.onload = function (e) {
							previewImage.src = e.target.result;
							modal.show();
						};
						reader.readAsDataURL(file);
					});
					div.appendChild(link);
				} else {
					div.textContent = file.name;
				}

				 
				const delIcon = document.createElement('a');
				delIcon.href = '#';
				delIcon.innerHTML = "<img src='../Assets/images/del.png' style='width:14px; height:14px; vertical-align:middle;' />";
				delIcon.style.marginLeft = "10px";
				delIcon.title = "Delete";
				delIcon.addEventListener('click', function (event) {
					event.preventDefault();
					files.splice(index, 1); // remove from array
					// Re-render remaining files
					const dt = new DataTransfer();
					files.forEach(f => dt.items.add(f));
					fileInput.files = dt.files;
					fileDisplay.value = files.map(f => f.name).join(', ') || 'No file chosen';
					div.remove();
				});
				div.appendChild(delIcon);
				listDiv.appendChild(div);
			});
		});
	});




</script>
