    function downloaddoc(element) {
        var grid = $("#attach_dataset").data("kendoGrid");
        var dataItem = grid.dataItem(element.closest("tr"));

        if (!dataItem) {
            console.error("No data item found for clicked row");
            return;
        }

        var attachment_gid = dataItem.attachment_gid;
        var originalFileName = dataItem.file_name;
        console.log("Downloadfilename:", originalFileName);

        if (!attachment_gid) {
            alert("Attachment ID not found for this record.");
            return;
        }

        //var downloadUrl = `../Ticket/DownloadAttachment?attachment_gid=${encodeURIComponent(attachment_gid)}&originalFileName=${encodeURIComponent(originalFileName)}`;
        var downloadUrl = `../Ticket/DownloadAttachment?attachment_gid=${attachment_gid}&originalFileName=${encodeURIComponent(originalFileName)}`;

        // ✅ First check if file exists (HEAD or GET with fetch)
        $.ajax({
            url: downloadUrl,
            type: 'GET',
            xhrFields: {
                responseType: 'blob' // expect binary
            },
            success: function (data, status, xhr) {
                const contentType = xhr.getResponseHeader("Content-Type");
                if (contentType && contentType.includes("application/json")) {
                    // Backend sent a message instead of file
                    const reader = new FileReader();
                    reader.onload = function () {
                        const response = JSON.parse(reader.result);
                        alert(response.message || "File not found.");
                    };
                    reader.readAsText(data);
                } else {
                    // ✅ File exists → trigger download
                    const blob = new Blob([data], { type: contentType });
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = originalFileName || 'download';
                    a.click();
                    window.URL.revokeObjectURL(url);
                }
            },
            error: function (xhr) {
                if (xhr.status === 404) {
                    alert("Attachment not found on the server.");
                } else {
                    alert("Error downloading attachment. Please try again.");
                }
            }
        });
    }


