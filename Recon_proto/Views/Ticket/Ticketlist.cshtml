    function ticket_dataset_details(data) {
        try {
            var role_code = sessionStorage.getItem("rolecode");
            var usernames = sessionStorage.getItem("username");
            var usercodes = sessionStorage.getItem("usrname");

            // Delete button
            var deleteBtn = "";
            if (role_code !== "RC027" && role_code !== "RC028") {
                deleteBtn = `<a href='javascript:void(0)' class='del-btn' title='Delete'>
                                <img src='../Assets/images/del.png' onclick='DelTicket($(this))'>
                            </a>`;
            }

            // Action buttons
            var actionTemplate =
                `<div class='action-buttons' style='text-align:center'>
                    <a href='javascript:void(0)' class='edit-btn' title='Edit'>
                        <img src='../Assets/images/editicons.png' onclick='editTicket($(this))'>
                    </a>
                    <a href='javascript:void(0)' class='view-btn' title='View'>
                        <img src='../Assets/images/viewicons.png' onclick='viewTicket($(this))'>
                    </a>
                    ${deleteBtn}
                </div>`;

            // Build columns
            var columnsList = [];

            if (role_code !== "RC027" && role_code !== "RC028") {
                columnsList.push({
                    title: "Select",
                    width: 60,
                    template:
                        "# if (status == 'New' || status == 'Reopened') { #" +
                        "<input type='checkbox' class='ticket-checkbox' data-id='#= ticket_gid #' />" +
                        "# } #",
                    headerAttributes: { style: "text-align:center" },
                    attributes: { style: "text-align:center" }
                });
            }

            columnsList.push({
                field: "Action",
                title: "Action",
                width: 80,
                hidden: true,
                encoded: false,
                editable: false,
                sortable: false,
                filterable: false,
                exportable: false,
                template: actionTemplate
            });

            columnsList.push(
                { field: "ticket_gid", title: "ticket_gid", width: 100, hidden: true },
                {
                    field: "ticket_no",
                    title: "Ticket No",
                    width: 140,
                    template: '<a href="javascript:void(0);" class="ticket-link">#= ticket_no #</a>'
                },
                { field: "creation_date", title: "Creation Date", width: 140, format: "{0:dd-MM-yyyy HH:mm:ss}" },
                { field: "type", title: "Type", width: 140 },
                { field: "priority", title: "Priority", width: 140 },
             //   { field: "insert_by", title: "Processed by", width: 150 },
                {
                    field: "insert_by",
                    title: "Processed By",
                    width: 150,
                    hidden: (role_code == "RC027")
                },
                { field: "status", title: "Status", width: 140 },
                { field: "raiser", title: "Raiser", width: 140 },
                { field: "assigned_to", title: "Assigned To", width: 140 },
                { field: "subject", title: "Subject", width: 140 },
                { field: "screen_name", title: "Screen Name", width: 140 },
                { field: "recon_name", title: "Recon Name", width: 140 },
                { field: "recon_code", title: "Recon Code", width: 140, hidden: true },
                { field: "report_name", title: "Report Name", width: 140 },
                { field: "entity", title: "entity", width: 10, hidden: true },
                { field: "department", title: "department", width: 10, hidden: true },
                { field: "unit", title: "unit", width: 10, hidden: true }
            );

            // Default filter
            var gridFilter = {};
            if (role_code == "RC006") {
                gridFilter = {
                    logic: "or",
                    filters: [
                        { field: "status", operator: "eq", value: "New" },
                        { field: "status", operator: "eq", value: "Reopened" }
                    ]
                };
            }
            if ($("#ticketModal").data("useKendoAppendTo")) {
                kendo.ui.FilterMenu.prototype.options.appendTo = "#ticketModal";
                kendo.ui.Popup.prototype.options.appendTo = "#ticketModal";
            }
            // Create Grid
            $("#ticket_dataset").kendoGrid({
                dataSource: {
                    data: data,
                    pageSize: 10,
                    filter: gridFilter,
                    schema: {
                        model: {
                            fields: {
                                ticket_gid: { type: "string" },
                                ticket_no: { type: "string" },
                                creation_date: { type: "date" },
                                raiser: { type: "string" },
                                assigned_to: { type: "string" },
                                subject: { type: "string" },
                                type: { type: "string" },
                                priority: { type: "string" },
                                status: { type: "string" },
                                insert_by: { type: "string" },
                                entity: { type: "string" },
                                department: { type: "string" },
                                unit: { type: "string" }
                            }
                        }
                    }
                },

                filterable: {
                    extra: true,
                    mode: "menu",
                    appendTo: "#ticketModal"
                },

                dataBound: function () {
                    var grid = this;

                    grid.tbody.find(".ticket-link").off("click").on("click", function (e) {
                        e.preventDefault();
                        var dataItem = grid.dataItem($(this).closest("tr"));
                        if (dataItem) editTicket(dataItem.ticket_gid);
                    });

                    grid.tbody.find("input.ticket-checkbox").each(function () {
                        var id = Number($(this).data("id"));
                        if (selectedTickets.includes(id)) $(this).prop("checked", true);
                    });

                    grid.tbody.find("input.ticket-checkbox").off("change").on("change", function () {
                        var id = Number($(this).data("id"));
                        if ($(this).is(":checked")) {
                            if (!selectedTickets.includes(id)) selectedTickets.push(id);
                        } else {
                            selectedTickets = selectedTickets.filter(x => x !== id);
                        }
                    });
                },

                pageable: {
                    refresh: false,
                    pageSizes: [10, 15, 20, 25, 50],
                    buttonCount: 5
                },

                excel: { fileName: "TicketData.xlsx", allPages: true },
                sortable: true,
                selectable: true,
                navigatable: true,
                resizable: true,
                editable: false,
                columns: columnsList
            });

            // Attach filter popup fix AFTER grid is created
            var grid = $("#ticket_dataset").data("kendoGrid");
            grid.bind("filterMenuInit", function (e) {
                $(document).off("focusin.bs.modal");
            });

        } catch (err) {
            console.log(err);
        }
    }

