	function openInfoWindow() {
		 var selectedOption = $("#cmbdoctype option:selected");
		 var code  = selectedOption.attr("code");
		 var result = JSON.parse(code);
		 openHtmlInNewWindow(result.info);
	}

	function openHtmlInNewWindow(htmlContent) {
		var selectedOption = $("#cmbdoctype option:selected");
		var win = window.open("width=3000,height=600,scrollbars=yes,resizable=yes");

		if (!win) {
			alert("Popup blocked. Please allow popups.");
			return;
		}

		win.document.open();
		win.document.title = selectedOption.text();
		win.document.write(htmlContent);
		win.document.close();
	}
	function grid_update(data) {
		$("#grid_update").kendoGrid({
			dataSource: {
				data: data,
				// pageSize: 5,
				schema: {
					model: {
						fields: {
							slno: { type: "number", editable: false },
							checklist_desc : { type: "string", editable: false, },
							checklist_category : { type: "string" },
							checklist_template : { type: "string", editable: false, },
							checklist_yesno: { type: "string"},
							reject_reason : { type: "string" },
							hold_flag : { type: "string" },
							reject_flag : { type: "string" },
						}
					}
				}
			},
			height: 288,
			groupable: false,
			dataBinding: setDefaultValues,
			scrollable: true,
			sortable: false,
			selectable: true,
			filterable: false,
			resizable: true,
			editable: true,
			pageable: false,
			dataBound: function (e) {
				var grid = e.sender;
				grid.tbody.off("click.yn").on("click.yn", ".ynRadio", function () {
					var radio = this;
					var row = $(radio).closest("tr");
					var dataItem = grid.dataItem(row);
					dataItem.set("checklist_yesno", radio.value);
					if (radio.value === "N") {
						dataItem.set("reject_reason", dataItem.checklist_template || "");
					} else {
						dataItem.set("reject_reason", "");
					}
					filterClaimStatusOptions();
				});

				grid.tbody.off("keydown.tabradio").on("keydown.tabradio", ".ynRadio", function (ev) {
				if (ev.key === "Tab") {
					ev.preventDefault();
					var row = $(this).closest("tr");
					grid.editCell(row.children("td").eq(2));
				}
			});
			},
			columns: [
				{
					field: "slno",
					title: "#",
					width: 40,
					hidden: true,
					editable: false
				},
				{
					field: "checklist_desc",
					title: "Checklist",
					width: 80,
					attributes: { class: "wrap-text" },
					headerAttributes: { class: "wrap-text" },
					editable: false,
					filterable: false,
				},
				{
					field: "checklist_category",
					title: "Hold/ Reject Category",
					width: 100,
					hidden: true,
				},
				{
					field: "checklist_yesno",
					title: "Yes / No",
					filterable: false,
					template: yesNoTemplate,
					width: 30
				},

				{
					field: "reject_reason",
					title: "Reject Reason",
					width: 100,
					attributes: { class: "wrap-text" },
					headerAttributes: { class: "wrap-text" },
					filterable: false,
					editor: rejectReasonEditor,
					template: function (dataItem) {
							return '<div class="wrap-text">' +
							  kendo.htmlEncode(dataItem.reject_reason || '') +
							'</div>';
					},
				},
				{
					field: "checklist_template",
					title: "Hold / Reject Reasons Template",
					width: 100,
					attributes: { class: "wrap-text" },
					headerAttributes: { class: "wrap-text" },
					filterable: false,
					hidden: true,
				},
				{
					field: "hold_flag",
					title: "hold_flag",
					width: 40,
					hidden: true,
				},
				{
					field: "reject_flag",
					title: "reject_flag",
					width: 40,
					hidden: true,
				},
			],
		});

	}
	function yesNoTemplate(dataItem) {
		var val = dataItem.checklist_yesno;
		return `
			<label>
				<input type="radio" class="ynRadio" name="rd_sel_${dataItem.uid}" value="Y" ${val === 'Y' ? 'checked' : ''}> Yes
			</label>
			<label>
				<input type="radio" class="ynRadio" name="rd_sel_${dataItem.uid}" value="N" ${val === 'N' ? 'checked' : ''}> No
			</label>
			<label>
				<input type="radio" class="ynRadio" name="rd_sel_${dataItem.uid}" value="NA" ${val === 'NA' ? 'checked' : ''}> N/A
			</label>
		`;
	}
	function bindRejectReasons(gridId, reasonStr) {
		var grid = $(gridId).data("kendoGrid");
		var arr = reasonStr.split(";").map(x => x.trim());

		grid.dataSource.data().forEach((item, i) => {
			if (arr[i] != "") {
				item.set("reject_reason", arr[i]);
				item.set("checklist_yesno", "N");
			} else {
				item.set("checklist_yesno", "Y");
			}

			var row = grid.tbody.find("tr").eq(i);
			row.find(`input[name="rd_sel_${item.slno}"]`).each(function () {
				$(this).prop("checked", $(this).val() === item.checklist_yesno);
			});
		});
		filterClaimStatusOptions();
	}

	$(document).on("keydown", ".holdRejectReasons", function (e) {
		protectTemplateInput(this, e);
	});
	function rejectReasonEditor(container, options) {
		var ta = $('<textarea rows="3" style="width:98%; padding:6px"></textarea>').appendTo(container);
		ta.val(options.model.reject_reason || "");
		const ranges = getEditableRanges(ta.val());
		if (ranges.length === 0) {
			ta.prop("readonly", true);
			return;
		}
		ta.on("keydown paste cut", function(e) {
			protectText(this, e);
		});
		ta.on("input", function() {
			options.model.set("reject_reason", this.value);
		});
		ta.on("focus", function() {
			if (ranges.length > 0) {
				this.setSelectionRange(ranges[0].start, ranges[0].end);
			}
		});
	}
	function getEditableRanges(value) {
		const ranges = [];
		const regex = /<[^>]*>/g;
		let m;

		while ((m = regex.exec(value)) !== null) {
			ranges.push({ start: m.index, end: m.index + m[0].length });
		}
		return ranges;
	}
	function protectText(textarea, e) {
		 const ranges = getEditableRanges(textarea.value);
		 if (ranges.length === 0) {
			 e.preventDefault();
			return;
		 }
		const pos = textarea.selectionStart;
		if (e.key === "Tab") {
			e.preventDefault();
			for (let r of ranges) {
				 if (pos < r.start) {
					  textarea.setSelectionRange(r.start, r.end);
					  return;
				}
			 }
			textarea.setSelectionRange(ranges[0].start, ranges[0].end);
		 return;
		}
		const val = textarea.value;


		if ((e.key === "Backspace" && val[pos - 1] === "<") || (e.key === "Delete" && val[pos] === ">")) {
			e.preventDefault();
			return;
		}
		const nav = ["ArrowLeft", "ArrowRight", "ArrowUp", "ArrowDown"];
		if (nav.includes(e.key)) return;
		const inside = ranges.some(r => pos > r.start && pos < r.end);
		if (!inside) {
			e.preventDefault();
			return;
		}
		ranges.forEach(r => {
			if ((e.key === "Backspace" && pos === r.start + 1) || (e.key === "Delete" && pos === r.end)) {
				 e.preventDefault();
			}
		});
	}
	function copyText() {
		var grid = $("#grid_update").data("kendoGrid");
		var data = grid.dataSource.data();
		var lines = [];
		data.forEach(function (item) {
			if (item.reject_reason && item.reject_reason.trim() !== "") {
				lines.push(item.reject_reason.trim());
			}
		});
		var finalText = lines
		.map((text, index) => (index + 1) + ") " + text)
		.join("\n");
		if(finalText != ""){
			var textarea = finalText + "\n\n" + "Note :" + $("#holdRejectReason").val();
		} else {
			var textarea = "Note : " + $("#holdRejectReason").val();
		}
		
		
		if (navigator.clipboard && window.isSecureContext) {
			navigator.clipboard.writeText(textarea);			 
		} else {
			fallbackCopy(textarea);
		}
	}

	function fallbackCopy(textarea) {
		textarea.select();
		textarea.setSelectionRange(0, textarea.length);

		try {
		   var success = document.execCommand("copy");
		  console.log(success ? "Copied (fallback)" : "Copy failed");
		} catch (err) {
			console.error("Copy not supported");
		}
	}
	function filterClaimStatusOptions() {
		var grid = $("#grid_update").data("kendoGrid");
		if (!grid) return;

		var hasNo = grid.dataSource.data().some(x => x.checklist_yesno === "N");

		var ddl = $("#cmbclaimsts");

		if (hasNo) {
			// Hide Approved & Pending
			ddl.find('option[value="Approved"]').hide();
			ddl.find('option[value="Pending"]').hide();
			ddl.find('option[value="Rejected"]').show();

			// If currently selected, reset
			if (ddl.val() === "Approved" || ddl.val() === "Pending" ) {
				ddl.val("");
			}
		} else {
			// Show them back
			ddl.find('option[value="Approved"]').show();
			ddl.find('option[value="Pending"]').show();
			ddl.find('option[value="Rejected"]').hide();
			ddl.find('option[value="Cancelled"]').hide();	
			// If currently selected, reset
			if (ddl.val() === "Rejected" || ddl.val() === "Cancelled" ) {
				ddl.val("");
			}
		}
	}
</script>
