</script>
<script>
	function getValueByDesc(desc) {
		return fields.find(f => f.field_desc === desc)?.field_value ?? "";
	}
	function getparentByDesc(desc) {
	   return fields.find(f => f.field_desc === desc)?.qcd_parent_code ?? "";
	}
	function getcolByDesc(desc) {
	   return fields.find(f => f.field_desc === desc)?.field_name ?? "";
	}

	function holdchange() {
		var multi = $("#cmbholdrjt").data("kendoMultiSelect");
		var dbValue = $("#holdRejectValue").val();

		var selectedValues = dbValue
			? dbValue.split(";").map(x => x.trim()).filter(Boolean)
			: [];

		if (multi) {
			multi.value([]);
			$("#holdRejectValue").val("");
			$("#holdRejectReasons").val("");
			preSelected = "";
		}

		arr = [];
		var jsondata = {};
		jsondata.in_tran_gid = getValueByDesc("Tran Id");
		jsondata.in_recon_field_name  = getcolByDesc("Reject/Hold Template") ;
		jsondata.in_recon_code = getValueByDesc("Recon Code");
		jsondata.in_tranbrkp_gid = $("#trabbrkid").val();
		jsondata.in_depend_code = $("#cmbdoctype :selected").text();
		jsondata.in_user_code = sessionStorage.getItem("usrname");

		$.ajax({
			type: "POST",
			url: '../KoSequence/reconfieldqcdlistexp',
			dataType: 'json',
			async: false,
			data: JSON.stringify(jsondata),
			contentType: 'application/json; charset=utf-8',
			success: function (response) {
				var result = JSON.parse(response);
				arr = result.filter(x =>  x.master_name  && x.master_name)
						.map(x => ({ value:  x.master_name , text: x.master_name ,code: x.master_multiple_name}));
				if (multi) {
					multi.dataSource.data(arr);
					multi.value(selectedValues);
					syncCheckboxes(multi);
				}
			}
		});
		var in_user_code = sessionStorage.getItem("usrname");
		var selectedOption = $("#cmbdoctype option:selected");
		var code  = selectedOption.attr("code");
		if ( code != "" ) {
			$.ajax({
				type: "POST",
				url: '../KoSequence/ecfchecklistinfo',
				dataType: 'json',
				async: false,
				data: JSON.stringify({ in_checklist_json: code,in_user_code: in_user_code }),
				contentType: 'application/json; charset=utf-8',
				success: function (response) {
					if (response != null) {
						var result = JSON.parse(response);
						result.Table1.forEach(function (item, index) {
							 item.slno = index + 1;
						 });
						grid_update(result.Table1);
					}
				}
			});
		}
		if($("#cmbdoctype :selected").val() != ""){
			$("#check1").prop('checked', false);
			$("#check2").prop('checked', true);			
			var bannertext1 = '<span style="color:bisque; font-weight:bold;">Document Type </span> : ' + $("#cmbdoctype :selected").text() ;
		$("#banner1").html(bannertext1);
		}
		var bannertext =
		'<span style="color:bisque; font-weight:bold;">Report ID </span> : ' + $("#reportid").val() +
		'&nbsp;&nbsp;<span style="color:bisque; font-weight:bold;">Employee ID </span> : ' + $("#employeeid").val() +
		'&nbsp;&nbsp;<span style="color:bisque; font-weight:bold;">Approved Amount </span> : ' + $("#approveamt").val() +
		'&nbsp;&nbsp;<span style="color:bisque; font-weight:bold;">Sub Category </span> : ' + $("#subcategory").val()
		$("#banner").html(bannertext);		
	}

	function syncCheckboxes(widget) {
		widget.ul.find("li").each(function () {
			var li = $(this);
			var checkbox = li.find("input[type='checkbox']");
			var dataItem = widget.dataItem(li.index());
			checkbox.prop("checked", widget.value().includes(dataItem.value));
		});
	}

	function updateValue(widget) {
		var value = widget.value().join(';');
		preSelected = value;
		$("#holdRejectValue").val(value);
	}

	function holdreject() {
		var multi = $("#cmbholdrjt").data("kendoMultiSelect");
		if (!multi) return;
		var items = multi.dataItems();
		var output = items
			 .filter(x => x.code && x.code.trim() !== "")
			 .map((x, index) => (index + 1) + ") " + x.code.trim())
			 .join("\n");
		$("#holdRejectReasons").val(output);
	}
	function validateChecklistYesNo(gridId) {
		var grid = $(gridId).data("kendoGrid");
		var data = grid.dataSource.data();
		var invalidRows = [];
		data.forEach(function (item, index) {
			if (!item.checklist_yesno || item.checklist_yesno.trim() === "" || item.checklist_yesno == undefined) {
				invalidRows.push(index + 1); // row number
			}
		});
		if (invalidRows.length > 0) {
			// alert("Please select Yes / No for all checklist rows.\nMissing rows: " + invalidRows.join(", "));
			return false;
		}
		return true;
	}
