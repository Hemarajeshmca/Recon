        function save_attachment() {
         $('#btnattach').prop("disabled", true);
        var ticket_gid = $("#ticket_gid").val();
        var queue_gid = 0;
        console.log("Attachment ticket_gid:", ticket_gid);
        console.log("Attachment queue_gid:", queue_gid);

        var uploadPromises = [];

        attachmentList.forEach(function (item) {
            if (item.attachment_gid == 0 && item.fileObject) {
                uploadPromises.push(AddAttachments(ticket_gid, queue_gid, item.fileObject));
            }
        });

        Promise.all(uploadPromises)
            .then(function (responses) {
                // Check if all were successful
                var allSuccess = responses.every(r => r.status === "success");

                if (allSuccess) {
                    $.alert({
                        title: "Recon",
                        content: "Attachments  uploaded successfully.",
                        type: "green",
                        buttons: {
                            ok: {
                                text: "OK",
                                btnClass: "btn-green",
                                action: function () {
                                    $('#ticketModal').modal('show');
                                    //$('button[data-bs-target="#navs-pills-top-list"]').show();
                                   // $('button[data-bs-target="#navs-pills-top-list"]').tab('show');
                                   // ticketlist();
                                }
                            }
                        }
                    });
                } else {
                    $.alert({
                        title: "Recon",
                        content: "Some attachments failed to upload.",
                        type: "red"
                    });
                }
                  $('#btnattach').prop("disabled", false);
                attachlist(ticket_gid);
            })
            .catch(function (err) {
                console.error("Error during upload:", err);
                  $('#btnattach').prop("disabled", false);
                $.alert({
                    title: "Recon",
                    content: "Error uploading attachments.",
                    type: "red"
                });
            });
    }

        function AddAttachments(ticket_gid, queue_gid, file) {
        return new Promise((resolve, reject) => {
            try {
                var usercode = sessionStorage.getItem("usrname");
                var formData = new FormData();

                formData.append("in_action", "INSERT");
                formData.append("attachment_gid", 0);
                formData.append("ticket_gid", ticket_gid);
                formData.append("queue_gid", queue_gid);
                formData.append("file", file);
                formData.append("in_user", usercode);
                formData.append("in_ip_addr", "");

                $.ajax({
                    type: "POST",
                    url: "../Ticket/addattachment",
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function (response) {
                        console.log("Attachment saved:", file.name);
                        resolve(response);
                    },
                    error: function (err) {
                        console.error("Error uploading file:", err);
                        reject(err);
                    }
                });
            } catch (e) {
                console.error(e);
                reject(e);
            }
        });
    }


