</script>
<script>
	function getValueByDesc(desc) {
		return fields.find(f => f.field_desc === desc)?.field_value ?? "";
	}
	function getparentByDesc(desc) {
	   return fields.find(f => f.field_desc === desc)?.qcd_parent_code ?? "";
	}
	function getcolByDesc(desc) {
	   return fields.find(f => f.field_desc === desc)?.field_name ?? "";
	}

	function holdchange() {
		var multi = $("#cmbholdrjt").data("kendoMultiSelect");
		var dbValue = $("#holdRejectValue").val();   

		var selectedValues = dbValue
			? dbValue.split(";").map(x => x.trim()).filter(Boolean)
			: [];
	
		if (multi) {
			multi.value([]);
			$("#holdRejectValue").val("");
			$("#holdRejectReasons").val("");
			preSelected = "";
		}	
	 
		arr = [];
		var jsondata = {};
		jsondata.in_tran_gid = getValueByDesc("Tran Id");
		jsondata.in_recon_field_name  = getcolByDesc("Reject/Hold Template") ;
		jsondata.in_recon_code = getValueByDesc("Recon Code");
		jsondata.in_tranbrkp_gid = $("#trabbrkid").val();
		jsondata.in_depend_code = $("#cmbdoctype :selected").text();
		jsondata.in_user_code = sessionStorage.getItem("usrname");

		$.ajax({
			type: "POST",
			url: '../KoSequence/reconfieldqcdlistexp',
			dataType: 'json',
			async: false,
			data: JSON.stringify(jsondata),
			contentType: 'application/json; charset=utf-8',
			success: function (response) {
				var result = JSON.parse(response);
				arr = result.filter(x =>  x.master_name  && x.master_name)
						.map(x => ({ value:  x.master_name , text: x.master_name ,code: x.master_multiple_name}));
				if (multi) {
					multi.dataSource.data(arr);
					multi.value(selectedValues);
					syncCheckboxes(multi);					
				}
			}
		});
	}

	function syncCheckboxes(widget) {
		widget.ul.find("li").each(function () {
			var li = $(this);
			var checkbox = li.find("input[type='checkbox']");
			var dataItem = widget.dataItem(li.index());
			checkbox.prop("checked", widget.value().includes(dataItem.value));
		});
	}
		
	function updateValue(widget) {
		var value = widget.value().join(';');
		preSelected = value;
		$("#holdRejectValue").val(value);
	}

	function holdreject() {
		var multi = $("#cmbholdrjt").data("kendoMultiSelect");
		if (!multi) return;
		var items = multi.dataItems();
		var output = items
			 .filter(x => x.code && x.code.trim() !== "")
			 .map((x, index) => (index + 1) + ") " + x.code.trim())
			 .join("\n");
		$("#holdRejectReasons").val(output);
	}

	function savereconexp() {
		var multi = $("#cmbholdrjt").data("kendoMultiSelect");
		var selectedfrm = "";
		if($("#cmbdoctype").val() =='')
		{
			$.alert({
				title: 'Recon',
				content: 'Document Type not selected',
				type: 'red',
			});
			return false;
		}
		if($("#cmbclaimsts").val() =='')
		{
			$.alert({
				title: 'Recon',
				content: 'Claim Status not selected',
				type: 'red',
			});
			return false;
		}
		if($("#cmbclaimsts").val() =='Hold' ||  $("#cmbclaimsts").val() =='Rejected' )
		{
			if(multi.value().length == 0) {
				$.alert({
				title: 'Recon',
				content: 'Hold/ Reject Category not selected',
				type: 'red',
			});
			return false;
			}			
		}
		var in_recon_code = getValueByDesc("Recon Code");
		var in_tran_gid = parseInt(getValueByDesc("Tran Id"));
		var in_tranbrkp_gid = parseInt($("#trabbrkid").val());
		var in_user_code = sessionStorage.getItem("usrname");
		var jsondata = {};
		jsondata.in_tran_gid = in_tran_gid;
		jsondata.in_recon_code = in_recon_code;
		jsondata.in_tranbrkp_gid = in_tranbrkp_gid;
		jsondata.in_user_code = in_user_code;
		$.ajax({
			type: "POST",
			url: '../KoSequence/setrecordunlock',
			dataType: 'json',
			async: true,
			data: JSON.stringify(jsondata),
			contentType: 'application/json; charset=utf-8',
			success: function (response) {
				var result = JSON.parse(response);				
			    selectedfrm =	multi.value().join(';');
				if (result[0].out_result == '1')
				{ 
					if($("#cmbclaimsts option:selected").text() == "Hold"){
						var json = [
						{
							field_name: "col99",
							field_value: $("#cmbdoctype option:selected").text()
						},
						{
							field_name: "col100",
							field_value: $("#cmbclaimsts option:selected").text()
						},
						{
							field_name: "col101",
							field_value: selectedfrm
						},
						{
							field_name: "col102",
							field_value: $("#holdRejectReasons").val()
						},
						{
							field_name: "col103",
							field_value: $("input[name='subhaapy']:checked").val()
						},
						{
							field_name: "col105",
							field_value: "Y"
						},
						{
							field_name: "col106",
							field_value: '@DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")'
						},
						{
							field_name: "col107",
							field_value: sessionStorage.getItem("usrname")
						},
						{
							field_name: "col108",							
							field_value: '@DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")'
						},
						{
							field_name: "col109",
							field_value: sessionStorage.getItem("usrname")
						}
						];
					} else {
						var json = [
						{
							field_name: "col99",
							field_value: $("#cmbdoctype option:selected").text()
						},
						{
							field_name: "col100",
							field_value: $("#cmbclaimsts option:selected").text()
						},
						{
							field_name: "col101",
							field_value: selectedfrm
						},
						{
							field_name: "col102",
							field_value: $("#holdRejectReasons").val()
						},
						{
							field_name: "col103",
							field_value: $("input[name='subhaapy']:checked").val()
						},
						{
							field_name: "col108",							
							field_value: '@DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")'
						},
						{
							field_name: "col109",
							field_value: sessionStorage.getItem("usrname")
						}
						];
					}	
					var in_curr_value = JSON.stringify(json);
					var in_new_value = JSON.stringify(json);

					$.ajax({
						type: "POST",
						url: '../KoSequence/reconfieldqcdsave',
						dataType: 'json',
						data: JSON.stringify({
							in_recon_code: in_recon_code, in_tran_gid: in_tran_gid, in_tranbrkp_gid: in_tranbrkp_gid,
							in_curr_value: in_curr_value, in_new_value: in_new_value, in_user_code: in_user_code
						}),
						contentType: 'application/json; charset=utf-8',
						success: function (response) {
							var res = JSON.parse(response);
							if (res[0].out_result == 1) {
								$.alert({
									title: 'Recon',
									content: res[0].out_msg,
									type: 'green',
								});
								sessionStorage.setItem("excpform", in_recon_code);
								window.location.href = "../KoSequence/Reconexception";
							}
							else {
								$.alert({
									title: 'Recon',
									content: res[0].out_msg,
									type: 'Red',
								});
							}
						},
						error: function (er) {
							alert(er)
							console.log(er)
						}
					});
				}
			}
		});
	}

	function copyText() {
		var textarea = document.getElementById("holdRejectReasons");

		if (!textarea || !textarea.value) {
			 console.log("Nothing to copy");
			  return;
		}

		// Modern browsers (HTTPS)
		if (navigator.clipboard && window.isSecureContext) {
			navigator.clipboard.writeText(textarea.value)
			  .then(() => console.log("Copied using clipboard API"))
			  .catch(() => fallbackCopy(textarea));
		} else {
			// HTTP fallback
			fallbackCopy(textarea);
	    }
    }

	function fallbackCopy(textarea) {
		textarea.select();
		textarea.setSelectionRange(0, textarea.value.length);

		try {
		   var success = document.execCommand("copy");
		  console.log(success ? "Copied (fallback)" : "Copy failed");
		} catch (err) {
		    console.error("Copy not supported");
		}
	}

	function openInfoWindow() {
		 var selectedOption = $("#cmbdoctype option:selected");		
		 var code  = selectedOption.attr("code");
		 openHtmlInNewWindow(code);
	}

	function openHtmlInNewWindow(htmlContent) {
		var selectedOption = $("#cmbdoctype option:selected")
		var win = window.open(			
			"width=3000,height=600,scrollbars=yes,resizable=yes"
		);

		if (!win) {
			alert("Popup blocked. Please allow popups.");
			return;
		}

		win.document.open();
		win.document.title = selectedOption.text();
		win.document.write(htmlContent);
		win.document.close();
	}		
	const textarea = document.getElementById("holdRejectReasons");

    function getRanges(value) {
        const ranges = [];
        const regex = /<[^>]*>/g;
        let match;
        while ((match = regex.exec(value)) !== null) {
            ranges.push({
                start: match.index + 1,
                end: match.index + match[0].length - 1
            });
        }
        return ranges;
    }

    function selectionInsideRange(start, end, ranges) {
        return ranges.some(r => start >= r.start && end <= r.end);
    }

    textarea.addEventListener("keydown", function (e) {
        const value = textarea.value;
        const ranges = getRanges(value);

        const selStart = textarea.selectionStart;
        const selEnd = textarea.selectionEnd;

        const allowedKeys = [
            "ArrowLeft", "ArrowRight", "ArrowUp", "ArrowDown",
            "Tab"
        ];

        const isSelection = selStart !== selEnd;
        const inside = selectionInsideRange(selStart, selEnd, ranges);

        /* ❌ Block delete/backspace if selection is outside <> */
        if ((e.key === "Backspace" || e.key === "Delete") && !inside) {
            e.preventDefault();
            return;
        }

        /* ❌ Block typing outside <> */
        if (!inside && !allowedKeys.includes(e.key)) {
            e.preventDefault();
            return;
        }

        /* ❌ Prevent deleting < or > */
        ranges.forEach(r => {
            if ((selStart === r.start && e.key === "Backspace") ||
                (selStart === r.end && e.key === "Delete")) {
                e.preventDefault();
            }
        });
    });

    // Block paste & cut
    //textarea.addEventListener("paste", e => e.preventDefault());
    //textarea.addEventListener("cut", e => e.preventDefault());
</script>