@{
	ViewBag.title = "Job Completed";
	Layout = "~/Views/Shared/_LayoutNew.cshtml";
}

<!Doctype html>
<html>
<head>
	<title></title>
	<style>

		.nav-item.me-2.me-xl-50 {
			margin-right: 33rem !important;
		}

		.error_show {
			color: red;
			margin-left: 10px;
		}

		table {
			border: 1px solid #C5C5C5 !important;
		}

		.k-grid-content {
			overflow-x: hidden;
		}

		.k-grid.k-widget {
			height: 360px;
		}

		.box {
			padding: 11px;
			border-radius: 5px;
			margin-top: 10px;
			margin-bottom: 10px;
		}

		.box-orange {
			background-color: white;
			border: 2px solid darkgreen;
		}

		.k-grid-header {
			font-weight: bold;
		}

		.k-grid-filter.k-state-active {
			color: #ffffff;
			background-color: #1274AC;
		}

		.k-content {
			font-weight: normal;
			font-size: 13px;
		}

		#grid_jobinprogress .k-state-selected td {
			background-color: #8b8b8b !important;
			color: white !important;
		}

		/* =========================
						   ANIMATION STYLES
						========================= */

		.job-details-box {
			transform-origin: top center;
			perspective: 1000px;
			display: none;
		}

		.flip-show {
			animation: flipShow 0.7s ease forwards;
		}

		.flip-hide {
			animation: flipHide 0.5s ease forwards;
		}

		.details-content {
			animation: fadeContent 0.8s ease;
		}

		@@keyframes flipShow {

			0% {
				opacity: 0;
				transform: rotateX(-90deg) scale(0.95);
			}

			50% {
				opacity: 0.7;
				transform: rotateX(20deg) scale(1.02);
			}

			100% {
				opacity: 1;
				transform: rotateX(0deg) scale(1);
			}
		}

		@@keyframes flipHide {

			0% {
				opacity: 1;
				transform: rotateX(0deg);
			}

			100% {
				opacity: 0;
				transform: rotateX(90deg);
			}
		}

		@@keyframes fadeContent {

			from {
				opacity: 0;
				transform: translateY(10px);
			}

			to {
				opacity: 1;
				transform: translateY(0px);
			}
		}

	</style>
</head>
<body class="hold-transition skin-blue sidebar-mini fixed">
	<div class="content-wrapper">
		<div class="container-xxl flex-grow-1 container-p-y">
			<div class="card-body" style="margin-top: -3%; min-height: 82%;">
				<div class="row" style="margin-bottom: 1%;margin-top: -1%;">
					<div class="col-md-3">
						<label class="form-label">Process Type<span style="font-size: 12px;color: red;font-weight: bold;">*</span></label>
						<select id="jobtype" class="form-select form-control"> </select>
					</div>
					<div class="col-md-3">
						<label for="" class="form-label">Initiated From Date<span style="font-size: 12px;color: red;font-weight: bold;">*</span></label>
						<div>
							<input class="cusDate" data-role='datepicker' id="initiated_from" name="initiated_from" style="width:100%" />
							<span data-for='valid' class='k-invalid-msg'></span>
						</div>
					</div>
					<div class="col-md-3">
						<label class="form-label"> Initiated To Date <span style="font-size: 12px;color: red;font-weight: bold;">*</span></label>
						<div>
							<input class="cusDate" data-role='datepicker2' id="initialed_to" name="initialed_to" data-value="2022-12-21" style="width:100%" />
							<span data-for='valid' class='k-invalid-msg'></span>
						</div>
					</div>
					<div class="col-md-3" style="margin-top: 2%;">
						<button type="button" class="btn btn-sm save_btn me-2" style="width:40%;margin-top: 7px" onclick="searchJob()">
							Search
						</button>
					</div>
				</div>
				<div id="gd_jobinprogress">
					<div id="grid_jobinprogress"> </div>
				</div>
				<div class="box box-orange" style="height:auto">
					<div class="row" style="padding-bottom:2px;padding-right:5px" id="jobDetailsBox">
						<div class="col-sm-3">
							<label for="" class="form-label">Job ID&nbsp</label>
							<input class="form-control" id="jobgid" type="text" disabled>
							<input class="form-control" id="filename" type="hidden" disabled />
							<input class="form-control" id="filetype" type="hidden" disabled>
						</div>
						<div class="col-sm-3">
							<label for="" class="form-label">Job Type&nbsp;</label>
							<input class="form-control" id="job_type" type="text" disabled>
						</div>
						<div class="col-sm-3">
							<label for="" class="form-label">Start Date&nbsp;</label>
							<input class="form-control" id="startdate" type="text" disabled>
						</div>
						<div class="col-sm-3">
							<label for="" class="form-label">End Date&nbsp;</label>
							<input class="form-control" id="enddate" type="text" disabled>
						</div>
						<div class="col-sm-3">
							<label for="" class="form-label">Job Remark&nbsp;</label>
							<input class="form-control" id="jobremark" type="text" disabled>
						</div>
						<div class="col-sm-3">
							<label for="" class="form-label">Initated By&nbsp;</label>
							<input class="form-control" id="initatedby" type="text" disabled>
						</div>
						<div class="col-sm-3">
							<label for="" class="form-label">Job Status&nbsp;</label>
							<input class="form-control" id="jobstatus" type="text" disabled>
						</div>
						<div class="col-sm-2" style="margin-top: 27px; width: 5%; margin-left: -4px;">
							<img style="height: 35px; width: 35px;cursor: pointer; margin-left: 4px;" title="Download" src="../Assets/images/download.png" onclick="downloadJob()" />
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</body>
</html>

<script type="text/javascript">
	$(document).ready(function () {
		$("#navhead").text("Job Completed");
		$("#contextdiv").hide();
		kendodate_format();
		getjobtypelist();
	});
	function getjobtypelist() {
		$.ajax({
			type: "POST",
			url: '../Utility/jobtypelist',
			dataType: 'json',
			data: JSON.stringify({}),
			contentType: 'application/json; charset=utf-8',
			success: function (response) {
				$("#jobtype").empty();
				$.each(response, function (index, item) {
					$("#jobtype").append($('<option>', {
						value: item.jobtype_code,
						text: item.jobtype_desc
					}));
				});
				searchJob();
			}
		});
	}
	function searchJob() {
		var fromDate = validateDateFormat($("#initiated_from").val());
		var toDate = validateDateFormat($("#initialed_to").val());
		if (fromDate && toDate) {
		try {
			var job_type = $("#jobtype").val();
			var period_from = $("#initiated_from").val();
			var ts = period_from.split("/");
			var start_date = ts[2] + "-" + ts[1] + "-" + ts[0];
			var period_end = $("#initialed_to").val();
			var te = period_end.split("/");
			var end_date = te[2] + "-" + te[1] + "-" + te[0];
			var action_by = sessionStorage.getItem("usrname");
			$.ajax({
				type: "POST",
				url: '../Utility/Joblistfetch',
				dataType: 'json',
					data: JSON.stringify({ in_start_date: start_date, in_end_date: end_date, in_jobtype_code: job_type, in_jobstatus: 'C', in_user_code: action_by }),
				contentType: 'application/json; charset=utf-8',
				success: function (response) {
					if (response != null) {
						$("#gd_jobinprogress").empty();
						$("#gd_jobinprogress").append("<div id='grid_jobinprogress'></div>");
						fetchGrid(response);
					}
					else {
						fetchGrid();
					}
				},
				error: function (er) {
					alert(er)
					console.log(er)
				}

			});
		}
		catch (e) {
			console.log(e)
		}
		} else if (!fromDate || !toDate) {
			$.alert({
				title: 'Recon',
				content: "Invalid Date ..!",
				type: 'red',
			});
		}
	}
	function fetchGrid(data) {
		try {
			var formatdatetime = sessionStorage.getItem("kendatetime");
			var formatdatetime1 = "{0:" + formatdatetime + "}";
			$("#grid_jobinprogress").kendoGrid({
				dataSource: {
					data: data,
					pageSize: 10,
					schema: {
						model: {
							fields: {
								end_date: { type: "date" },
								job_gid: { type: "number" },
								job_name: { type: "string" },
								job_remark: { type: "string" },
								jobstatus_desc: { type: "string" },
								jobtype_code: { type: "string" },
								jobtype_desc: { type: "string" },
								start_date: { type: "date" },
								recon_code: { type: "string" },
								recon_name: { type: "string" },
								file_type: { type: "string" },
								job_initiated_by: { type: "string" },
								file_name: { type: "string" }
							}
						},
						parse: function (data) {
							$.each(data, function (i, item) {
								item.start_date = kendo.parseDate(item.start_date, formatdatetime);
								item.end_date = kendo.parseDate(item.end_date, formatdatetime);
							});
							return data;
						}
					}
				},
				height: 300,
				change: onRowSelect,
				groupable: false,
				dataBound: function (e) {
					resultData = e.sender._data;
					var rows = $('#grid_jobinprogress').data('kendoGrid').tbody.children();
					setColor(rows, resultData);
					var grid = e.sender;
					var firstRow = grid.tbody.find("tr:first");
					grid.select(firstRow);
					onRowSelect();
				},
				pageable: {
					refresh: false,
					pageSizes: true,
					buttonCount: 5
				},
				sortable: true,
				selectable: true,
				filterable: true,
				navigatable: true,
				resizable: true,
				columns: [
					// {
					// 	command: [
					// 		{
					// 			name: "download",
					// 			id: "btn_download",
					// 			template: "<a href='' onclick='downloadJob(this)' value='job_id' data-bs-toggle='modal'><img style='height: 20px;width: 20px;' src = '../Assets/images/download.png'></a>&nbsp;&nbsp;&nbsp;",
					// 		},
					// 	],
					// 	title: "Action&nbsp;",
					// 	width: "50px",
					// 	attributes: { style: "text-align: center;" },
					// },
					{
						field: "job_gid",
						title: "Job Id",
						width: 55,
						attributes: { style: "text-align: right;" },
						filterable: {
							ui: "numeric",
							extra: false,
						},
					},
					{
						field: "job_name",
						title: "Job Name",
						width: 125,
					},
					{
						field: "jobtype_code",
						title: "Job Type Code",
						width: 100,
						hidden: true
					},
					{
						field: "jobtype_desc",
						title: "Job Type",
						width: 100,
						hidden: true,
					},
					{
						field: "recon_name",
						title: "Recon Name",
						width: 125,
					},
					{
						field: "start_date",
						title: "Start Date",
						format: formatdatetime1,
						width: 90,
						filterable: {
							ui: function (element) {
								element.kendoDateTimePicker({
									format: formatdatetime1,
								});
							},
						},
						hidden: true,
					},
					{
						field: "end_date",
						title: "Completed Date",
						format: formatdatetime1,
						width: 90,
						filterable: {
							ui: function (element) {
								element.kendoDateTimePicker({
									format: formatdatetime1,
								});
							},
						},
					},
					{
						field: "job_remark",
						title: "Job Remark",
						width: 100,
						hidden: true,
					},
					{
						field: "job_initiated_by",
						title: "Initated By",
						width: 90,
					},
					{
						field: "jobstatus_desc",
						title: "Job Status",
						width: 125,
					},
					{
						field: "jobtype_code",
						title: "Job Type Code",
						hidden: true
					},
					{
						field: "file_type",
						title: "File Type",
						width: 50,
						hidden: true
					},
					{
						filed: "file_name",
						title: "file_name",
						width: 10,
						hidden: true
					}
				],
				editable: false,
			});
		} catch (err) {
			console.log(err);
		}
	}
	// function onRowSelect(e) {
	// 	var formatdatetimefetch = sessionStorage.getItem("kendatetime");
	// 	var grid = $("#grid_jobinprogress").data("kendoGrid");
	// 	var selectedRow = grid.select();
	// 	var dataItem = grid.dataItem(selectedRow);
	// 	// bind values to textbox
	// 	$("#jobgid").val(dataItem.job_gid);
	// 	$("#job_type").val(dataItem.jobtype_desc);
	// 	$("#startdate").val(kendo.toString(dataItem.start_date, formatdatetimefetch));
	// 	$("#enddate").val(kendo.toString(dataItem.end_date, formatdatetimefetch));
	// 	$("#jobremark").val(dataItem.job_remark);
	// 	$("#initatedby").val(dataItem.job_initiated_by);
	// 	$("#jobstatus").val(dataItem.jobstatus_desc);
	// 	$("#filename").val(dataItem.file_name);
	// 	$("#filetype").val(dataItem.file_type);
	// }
	function downloadJob(val) {
		var job_gid = $("#jobgid").val();
		var file_name = $("#filename").val();
		var filetype = $("#filetype").val();
		var user_code = sessionStorage.getItem("usrname");
		if (filetype != 'xlsx') {
			window.location.href = '@Url.Action("Downloads", "Utility")?jobid=' + job_gid + '&filetype=' + 'csv' + '&file_name=' + file_name + '' + '&username=' + user_code + '';
		} else {
			window.location.href = '@Url.Action("Downloads", "Utility")?jobid=' + job_gid + '&filetype=' + 'xlsx' + '&file_name=' + file_name + '' + '&username=' + user_code + '';
		}
	}

	document.addEventListener('DOMContentLoaded', function () {
		const dateInput = document.getElementById('initiated_from');
		const dateInput1 = document.getElementById('initialed_to');
		dateInput.addEventListener('focusout', onFocusOut);
		dateInput1.addEventListener('focusout', onFocusOut);
	});
		function onRowSelect(e) {

		var formatdatetimefetch = sessionStorage.getItem("kendatetime");

		var grid = $("#grid_jobinprogress").data("kendoGrid");
		var selectedRow = grid.select();
		var dataItem = grid.dataItem(selectedRow);

		var box = $("#jobDetailsBox");

		// If already visible -> flip vanish first
		if (box.is(":visible")) {

			box.removeClass("flip-show").addClass("flip-hide");

			setTimeout(function () {

				loadJobDetails(dataItem);

				box.show();
				box.removeClass("flip-hide").addClass("flip-show");

			}, 500);

		}
		else {

			loadJobDetails(dataItem);

			box.show();
			box.addClass("flip-show");
		}
	}

	function loadJobDetails(dataItem) {

		var formatdatetimefetch = sessionStorage.getItem("kendatetime");

		$("#jobgid").val(dataItem.job_gid);
		$("#job_type").val(dataItem.jobtype_desc);
		$("#startdate").val(kendo.toString(dataItem.start_date, formatdatetimefetch));
		$("#enddate").val(kendo.toString(dataItem.end_date, formatdatetimefetch));
		$("#jobremark").val(dataItem.job_remark);
		$("#initatedby").val(dataItem.job_initiated_by);
		$("#jobstatus").val(dataItem.jobstatus_desc);
		$("#filename").val(dataItem.file_name);
		$("#filetype").val(dataItem.file_type);
	}
</script>