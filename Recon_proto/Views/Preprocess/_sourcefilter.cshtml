@model Recon_proto.Controllers.PreprocessController.partialfetchmodel
@using Newtonsoft.Json.Linq
@{
	JObject json = null;
	if (!string.IsNullOrEmpty(Model?.partialdata))
	{
		json = JObject.Parse(Model.partialdata);
	}
	var sourcefilter = json?["sourcefilter"];
}
<div class="accordion-wrapper">
	<div class="accordion" id="headingsourcefilter">
		<input type="checkbox" name="radio-a" id="check13" style="display:none">
		<label class="accordion-label" for="check13">&nbsp;&nbsp;&nbsp;Source Filter</label>
		<div class="accordion-content" id="headingsourcefilter">
			<div class="row" style="margin-bottom:5px;">
				<div class="col-xs-12" style="margin-top:5px;">
					<div id="gd_sourcefilter">
						<div id="grid_sourcefilter">
						</div>
					</div>
				</div>
			</div>
		</div>
